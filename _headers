# Cloudflare Pages cache + security headers
# Docs: https://developers.cloudflare.com/pages/platform/headers/

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), camera=(), microphone=(), geolocation=()

# Long-cache fingerprintable assets (all assets are versioned by deploy commit
# so a fresh hash is implicit). HTML/JS/CSS get a shorter cache so deploys
# are visible quickly.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=300, must-revalidate

/js/*
  Cache-Control: public, max-age=300, must-revalidate

/index.html
  Cache-Control: public, max-age=60, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate
