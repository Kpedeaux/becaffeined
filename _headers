# Cloudflare Pages cache + security headers
# Docs: https://developers.cloudflare.com/pages/platform/headers/

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), camera=(), microphone=(), geolocation=()

# Long-cache fingerprintable assets (all assets are versioned by deploy commit
# so a fresh hash is implicit). HTML/JS/CSS get a shorter cache so deploys
# are visible quickly.

# Long-lived cache for fonts and brand logos — these rarely change.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

# Drink art and splash photos change as we iterate. 1 hour browser cache
# with revalidate so a deploy is visible quickly without a hard refresh.
# We additionally version-stamp these URLs from JS to bypass cache on
# any user already holding a stale copy.
/assets/svg/*
  Cache-Control: public, max-age=3600, must-revalidate

/assets/splash/*
  Cache-Control: public, max-age=3600, must-revalidate

/css/*
  Cache-Control: public, max-age=300, must-revalidate

/js/*
  Cache-Control: public, max-age=300, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate
